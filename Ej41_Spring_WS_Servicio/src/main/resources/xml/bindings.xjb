<jaxb:bindings xmlns:jaxb="https://jakarta.ee/xml/ns/jaxb"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               version="3.0">
    <jaxb:bindings schemaLocation="clientes.xsd">
        <jaxb:bindings node="//xs:complexType[@name='cliente']">
            <jaxb:class name="ClienteDTO"/>
        </jaxb:bindings>
    </jaxb:bindings>
</jaxb:bindings>